_FILE = \"chat_memory.json\"\n","\n","def load_memory():\n","    if os.path.exists(MEMORY_FILE):\n","        with open(MEMORY_FILE, \"r\") as f:\n","            return json.load(f)\n","    return []\n","\n","def save_memory(memory):\n","    with open(MEMORY_FILE, \"w\") as f:\n","        json.dump(memory, f, indent=2)\n","\n","def clean_memory(memory):\n","    now = datetime.now()\n","    return [\n","        msg for msg in memory\n","        if now - datetime.fromisoformat(msg[\"time\"]) <= timedelta(days=70)\n","    ]\n","\n","# ================= PDF =================\n","def create_pdf(text, filename=\"answer.pdf\"):\n","    doc = SimpleDocTemplate(filename)\n","    styles = getSampleStyleSheet()\n","    doc.build([Paragraph(text, styles[\"Normal\"])])\n","\n","    print(f\"📄 Saved at: {os.path.abspath(filename)}\")\n","\n","# ================= IMAGE =================\n","def generate_image(prompt):\n","    model_img = genai.GenerativeModel(\"models/gemini-2.5-flash-image\")\n","\n","    if \"diagram\" in prompt or \"flowchart\" in prompt:\n","        prompt += \" clean, labeled, professional diagram\"\n","\n","    response = model_img.generate_content(prompt)\n","\n","    for part in response.candidates[0].content.parts:\n","        if hasattr(part, \"inline_data\"):\n","            image_bytes = part.inline_data.data\n","\n","            with open(\"generated.png\", \"wb\") as f:\n","                f.write(image_bytes)\n","\n","            print(\"🖼️ Image saved as generated.png\")\n","            display(Image(\"generated.png\"))\n","\n","# ================= SIMILARITY =================\n","def cosine_similarity(a, b):\n","    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b))\n","\n","# ================= FILE PROCESS =================\n","def process_files():\n","    global all_text, chunks, embeddings\n","\n","    uploaded = files.upload()\n","\n","    for filename in uploaded.keys():\n","        print(f\"\\n📂 Processing: {filename}\")\n","        text = \"\"\n","\n","        try:\n","            if filename.endswith(\".pdf\"):\n","                with pdfplumber.open(filename) as pdf:\n","                    for page in pdf.pages:\n","                        text += page.extract_text() or \"\"\n","\n","                if len(text.strip()) < 50:\n","                    print(\"⚠️ OCR...\")\n","                    images = convert_from_path(filename)\n","                    for img in images:\n","                        text += pytesseract.image_to_string(img)\n","\n","            elif filename.endswith(\".docx\"):\n","                doc = Document(filename)\n","                for para in doc.paragraphs:\n","                    text += para.text + \"\\n\"\n","\n","            elif filename.endswith(\".pptx\"):\n","                ppt = Presentation(filename)\n","                for slide in ppt.slides:\n","                    for shape in slide.shapes:\n","                        if hasattr(shape, \"text\"):\n","                            text += shape.text + \"\\n\"\n","\n","        except Exception as e:\n","            print(\"❌ Error:\", e)\n","\n","        print(\"✅ Length:\", len(text))\n","        all_text += f\"\\n\\n--- {filename} ---\\n{text}\"\n","\n","    print(\"\\n🔥 TOTAL TEXT:\", len(all_text))\n","\n","    # 🔥 CHUNKING\n","    chunks.clear()\n","    chunk_size = 1500\n","\n","    for i in range(0, len(all_text), chunk_size):\n","        chunks.append(all_text[i:i+chunk_size])\n","\n","    print(\"✅ Chunks:\", len(chunks))\n","\n","    # 🔥 EMBEDDINGS\n","    embeddings.clear()\n","    for chunk in chunks:\n","        emb = genai.embed_content(\n","            model=\"models/gemini-embedding-001\",\n","            content=chunk\n","        )[\"embedding\"]\n","        embeddings.append(emb)\n","\n","    print(\"✅ Embeddings ready\")\n","\n","# ================= MODEL =================\n","model = genai.GenerativeModel(\"models/gemini-2.5-flash\")\n","\n","# ================= LOAD MEMORY ====