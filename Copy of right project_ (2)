\n","\u001b[0;32m/usr/local/lib/python3.12/dist-packages/google/ai/generativelanguage_v1beta/services/generative_service/transports/rest.py\u001b[0m in \u001b[0;36m__call__\u001b[0;34m(self, request, retry, timeout, metadata)\u001b[0m\n\u001b[1;32m   1159\u001b[0m             \u001b[0;31m# subclass.\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m   1160\u001b[0m             \u001b[0;32mif\u001b[0m \u001b[0mresponse\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mstatus_code\u001b[0m \u001b[0;34m>=\u001b[0m \u001b[0;36m400\u001b[0m\u001b[0;34m:\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0;32m-> 1161\u001b[0;31m                 \u001b[0;32mraise\u001b[0m \u001b[0mcore_exceptions\u001b[0m\u001b[0;34m.\u001b[0m\u001b[0mfrom_http_response\u001b[0m\u001b[0;34m(\u001b[0m\u001b[0mresponse\u001b[0m\u001b[0;34m)\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n\u001b[0m\u001b[1;32m   1162\u001b[0m \u001b[0;34m\u001b[0m\u001b[0m\n\u001b[1;32m   1163\u001b[0m             \u001b[0;31m# Return the response\u001b[0m\u001b[0;34m\u001b[0m\u001b[0;34m\u001b[0m\u001b[0m\n","\u001b[0;31mTooManyRequests\u001b[0m: 429 POST https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?%24alt=json%3Benum-encoding%3Dint: You exceeded your current quota, please check your plan and billing details. For more information on this error, head to: https://ai.google.dev/gemini-api/docs/rate-limits. To monitor your current usage, head to: https://ai.dev/rate-limit. \n* Quota exceeded for metric: generativelanguage.googleapis.com/generate_content_free_tier_input_token_count, limit: 0, model: gemini-2.5-flash-preview-image\n* Quota exceeded for metric: generativelanguage.googleapis.com/generate_content_free_tier_requests, limit: 0, model: gemini-2.5-flash-preview-image\n* Quota exceeded for metric: generativelanguage.googleapis.com/generate_content_free_tier_requests, limit: 0, model: gemini-2.5-flash-preview-image\nPlease retry in 34.139030345s."]}],"source":["import numpy as np\n","import google.generativeai as genai\n","from reportlab.platypus import SimpleDocTemplate, Paragraph\n","from reportlab.lib.styles import getSampleStyleSheet\n","import os, json\n","from datetime import datetime, timedelta\n","\n","# 🔥 FILE + OCR IMPORTS\n","from google.colab import files\n","import pdfplumber\n","import pytesseract\n","from pdf2image import convert_from_path\n","from docx import Document\n","from pptx import Presentation\n","\n","# 🔥 IMAGE DISPLAY\n","from IPython.display import Image, display\n","\n","# ================= CONFIG =================\n","genai.configure(api_key=os.getenv(\"GOOGLE_API_KEY\"))\n","\n","# ================= GLOBAL =================\n","all_text = \"\"\n","chunks = []\n","embeddings = []\n","cache = {}\n","\n","# ================= MEMORY =================\n","MEMORY_FILE = \"chat_memory.json\"\n","\n","def load_memory():\n","    if os.path.exists(MEMORY_FILE):\n","        with open(MEMORY_FILE, \"r\") as f:\n","            return json.load(f)\n","    return []\n","\n","def save_memory(memory):\n","    with open(MEMORY_FILE, \"w\") as f:\n","        json.dump(memory, f, indent=2)\n","\n","def clean_memory(memory):\n","    now = datetime.now()\n","    return [\n","        msg for msg in memory\n","        if now - datetime.fromisoformat(msg[\"time\"]) <= timedelta(days=70)\n","    ]\n","\n","# ================= PDF =================\n","def create_pdf(text, filename=\"answer.pdf\"):\n","    doc = SimpleDocTemplate(filename)\n","    styles = getSampleStyleSheet()\n","    doc.build([Paragraph(text, styles[\"Normal\"])])\n","\n","    print(f\"📄 Saved at: {os.path.abspath(filename)}\")\n","\n","# ================= IMAGE =================\n","def generate_image(prompt):\n","    model_img = genai.GenerativeModel(\"models/gemini-2.5-flash-image\")\n","\n","    if \"diagram\" in prompt or \"flowchart\" in prompt:\n","        prompt += \" clean, labeled, professional diagram\"\n","\n","    response = model_img.generate_content(prompt)\n","\n","    for part in response.candidates[0].content.parts:\n","        if hasattr(part, \"inline_data\"):\n","            image_bytes = part.inline_data.data\n","\n","            with open(\"generated.png\", \"wb\") as f:\n","                f.write(image_bytes)\n","\n","            print(\"🖼️ Image saved as generated.png\")\n","            display(Image(\"generated.png\"))\n","\n","# ================= SIMILARITY =================\n","def cosine_similarity(a, b):\n","    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b))\n","\n","# ================= FILE PROCESS =================\n","def process_files():\n","    global all_text, chunks, embeddings\n","\n","    uploaded = files.upload()\n","\n","    for filename in uploaded.keys():\n","        print(f\"\\n📂 Processing: {filename}\")\n","        text = \"\"\n","\n","        try:\n","            if filename.endswith(\".pdf\"):\n","                with pdfplumber.open(filename) as pdf:\n","                    for page in pdf.pages:\n","                        text += page.extract_text() or \"\"\n","\n","                if len(text.strip()) < 50:\n","                    print(\"⚠️ OCR...\")\n","                    images = convert_from_path(filename)\n","                    for img in images:\n","                        text += pytesseract.image_to_string(img)\n","\n","            elif filename.endswith(\".docx\"):\n","                doc = Document(filename)\n","                for para in doc.paragraphs:\n","                    text += para.text + \"\\n\"\n","\n","            elif filename.endswith(\".pptx\"):\n","                ppt = Presentation(filename)\n","                for slide in ppt.slides:\n","                    for shape in slide.shapes:\n","                        if hasattr(shape, \"text\"):\n","                            text += shape.text + \"\\n\"\n","\n","        except Exception as e:\n","            print(\"❌ Error:\", e)\n","\n","        print(\"✅ Length:\", len(text))\n","        all_text += f\"\\n\\n--- {filename} ---\\n{text}\"\n","\n","    print(\"\\n🔥 TOTAL TEXT:\", len(all_text))\n","\n","    # 🔥 CHUNKING\n","    chunks.clear()\n","    chunk_size = 1500\n","\n","    for i in range(0, len(all_text), chunk_size):\n","        chunks.append(all_text[i:i+chunk_size])\n","\n","    print(\"✅ Chunks:\", len(chunks))\n","\n","    # 🔥 EMBEDDINGS\n","    embeddings.clear()\n","    for chunk in chunks:\n","        emb = genai.embed_content(\n","            model=\"models/gemini-embedding-001\",\n","            content=chunk\n","        )[\"embedding\"]\n","        embeddings.append(emb)\n","\n","    print(\"✅ Embeddings ready\")\n","\n","# ================= MODEL =================\n","model = genai.GenerativeModel(\"models/gemini-2.5-flash\")\n","\n","# ================= LOAD MEMORY =================\n","memory = clean_memory(load_memory())\n","\n","print(\"🤖 Chatbot Ready!\")\n","print(\"Commands: upload / ask / image / exit\\n\")\n","\n","# ================= LOOP =================\n","while True:\n","    cmd = input(\"Command: \")\n","\n","    if cmd == \"exit\":\n","        break\n","\n","    elif cmd == \"upload\":\n","        process_files()\n","\n","    elif cmd == \"image\":\n","        prompt = input(\"Describe image: \")\n","        generate_image(prompt)\n","\n","    elif cmd == \"ask\":\n","        question = input(\"You: \")\n","\n","        # 🔥 AUTO IMAGE DETECT\n","        if \"draw\" in question or \"diagram\" in question:\n","            generate_image(question)\n","            continue\n","\n","        if question in cache:\n","            print(\"⚡ From Cache\")\n","            answer = cache[question]\n","\n","        else:\n","            query_embedding = genai.embed_content(\n","                model=\"models/gemini-embedding-001\",\n","                content=question\n","            )[\"embedding\"]\n","\n","            scores = [cosine_similarity(query_embedding, emb) for emb in embeddings]\n","            best_index = np.argmax(scores)\n","\n","            prompt = f\"\"\"\n","            Context:\n","            {chunks[best_index]}\n","\n","            Question: {question}\n","            \"\"\"\n","\n","            response = model.generate_content(prompt)\n","            answer = response.text\n","\n","            cache[question] = answer\n","\n","        print(\"\\nAI:\", answer)\n","\n","        # 🔹 SAVE MEMORY\n","        memory.append({\n","            \"role\": \"User\",\n","            \"text\": question,\n","            \"time\": datetime.now().isoformat()\n","        })\n","\n","        memory.append({\n","            \"role\": \"AI\",\n","            \"text\": answer,\n","            \"time\": datetime.now().isoformat()\n","        })\n","\n","        save_memory(memory)\n","\n","        # 🔹 PDF\n","        if \"pdf\" in question.lower():\n","            create_pdf(answer)"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"gYXyCb7j96_z"},"outputs":[],"source":["from reportlab.platypus import SimpleDocTemplate, Paragraph\n","from reportlab.lib.styles import getSampleStyleSheet\n","\n","def create_pdf(text, filename=\"output.pdf\"):\n","    doc = SimpleDocTemplate(filename)\n","    styles = getSampleStyleSheet()\n","\n","    content = []\n","    content.append(Paragraph(text, styles[\"Normal\"]))\n","\n","    doc.build(content)\n","\n","    print(f\"📄 PDF saved as {filename}\")"]}],"metadata":{"colab":{"provenance":[{"file_id":"1o7etQcDAAO9Q1sWAdF_6pmv-CODShkMI","timestamp":1775796259186}]},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}